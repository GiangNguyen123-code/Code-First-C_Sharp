@model CodeFirst_Student.Models.Student

@{
    ViewData["Title"] = "Xác nhận xóa";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> XÁC NHẬN XÓA</h4>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="bi bi-trash3 text-danger" style="font-size: 4rem;"></i>
                    </div>
                    
                    <h5 class="text-secondary mb-3">Bạn có chắc chắn muốn xóa sinh viên này không?</h5>
                    <p class="text-muted small">Hành động này sẽ xóa vĩnh viễn dữ liệu và không thể hoàn tác.</p>
                    
                    <div class="bg-light p-3 rounded-3 mb-4 text-start">
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-bold text-muted">Họ và Tên:</div>
                            <div class="col-sm-8 text-dark">@Html.DisplayFor(model => model.Name)</div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4 fw-bold text-muted">Tuổi:</div>
                            <div class="col-sm-8 text-dark">@Html.DisplayFor(model => model.Age) tuổi</div>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg shadow-sm">
                                <i class="bi bi-check-lg"></i> Đồng ý xóa
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg"></i> Hủy bỏ và quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="text-center mt-3 text-danger small font-italic">
                <i class="bi bi-info-circle"></i> Vui lòng kiểm tra kỹ thông tin trước khi xác nhận.
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">